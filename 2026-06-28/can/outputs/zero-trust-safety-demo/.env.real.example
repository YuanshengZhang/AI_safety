# Optional real-stack integrations for the zero-trust safety demo.
# Copy values into your shell before starting server.py.

# Real OpenAI-compatible LLM, for example vLLM serving Qwen32B:
# vllm serve Qwen/Qwen2.5-32B-Instruct --host 127.0.0.1 --port 8000
USE_REAL_LLM=1
LLM_API_BASE=http://127.0.0.1:8000/v1
LLM_MODEL=Qwen/Qwen2.5-32B-Instruct
LLM_API_KEY=
OPENAI_API_KEY=
LLM_TIMEOUT_SECONDS=30

# Alternative: use OpenAI directly instead of local vLLM.
# USE_REAL_LLM=1
# LLM_API_BASE=https://api.openai.com/v1
# LLM_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=sk-...

# Real Docker sandbox for approved shell commands.
USE_DOCKER=1
DOCKER_SANDBOX_IMAGE=alpine:3.20
DOCKER_SANDBOX_TIMEOUT_SECONDS=10
DOCKER_SANDBOX_MEMORY=512m
DOCKER_SANDBOX_CPUS=1

# Real OpenBao KV v2 vault for token -> raw PII mappings.
USE_OPENBAO=1
OPENBAO_ADDR=http://127.0.0.1:8200
OPENBAO_TOKEN=root
OPENBAO_KV_MOUNT=secret
OPENBAO_KV_PREFIX=zero-trust-demo/session

# Real NeMo Guardrails if nemoguardrails is installed and configured.
USE_NEMO=1
NEMO_CONFIG_PATH=./nemo_guardrails_config
